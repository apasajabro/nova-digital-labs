---
import GoogleSiteTools from '../components/system/GoogleSiteTools.astro';
import '../styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { company } from '@/config/company';
import { site } from '@/config/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const title = Astro.props.title
  ? `${Astro.props.title} | ${company.legalName}`
  : `${company.legalName} | ${company.tagline}`;

const description = Astro.props.description ?? company.description;
const image = Astro.props.image ?? site.ogImage;
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const noindex = Astro.props.noindex ?? false;
---

<!doctype html>
<html lang={site.defaultLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content={company.legalName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <meta name="theme-color" content={site.themeColor} />

    <link rel="icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <GoogleSiteTools />
  </head>

  <body>
    <div class="site-ambient" aria-hidden="true"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
