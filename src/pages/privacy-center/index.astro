---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { company } from '../../config/company';
import { privacyPolicies } from '../../data/privacy-policies';
---

<BaseLayout
  title={`Privacy Policy Center — ${company.legalName}`}
  description={`Privacy policy center for applications and digital products published by ${company.legalName}.`}
>
  <section class="section-padding">
    <div class="container-page">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.32em] text-orange-200">
          Privacy Policy Center
        </p>

        <h1 class="mt-5 text-4xl font-black tracking-tight text-white sm:text-5xl">
          Application Privacy Policies
        </h1>

        <p class="mt-6 text-base leading-8 text-orange-50/65">
          Official privacy policy documents for applications and digital products published,
          managed, or supported by {company.legalName}.
        </p>
      </div>

      <div class="mx-auto mt-14 max-w-5xl">
        <div class="overflow-hidden rounded-[2rem] border border-white/15 bg-white/[0.07] shadow-soft backdrop-blur-xl">
          <div class="border-b border-white/10 px-6 py-5 sm:px-8">
            <p class="text-sm font-bold text-white">
              Available Privacy Policy Documents
            </p>
            <p class="mt-1 text-sm text-orange-50/55">
              Select an application to view its privacy policy.
            </p>
          </div>

          <div class="divide-y divide-white/10">
            {privacyPolicies.map((policy) => (
              <article class="grid gap-5 px-6 py-6 transition hover:bg-white/[0.04] sm:px-8 lg:grid-cols-[1fr_auto] lg:items-center">
                <div>
                  <div class="flex flex-wrap items-center gap-3">
                    <h2 class="text-xl font-black text-white">
                      {policy.appName}
                    </h2>

                    <span class="rounded-full border border-orange-200/20 bg-orange-300/10 px-3 py-1 text-xs font-bold text-orange-100">
                      Mobile App
                    </span>
                  </div>

                  <p class="mt-3 max-w-3xl text-sm leading-7 text-orange-50/60">
                    {policy.shortDescription}
                  </p>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {policy.features.ads && (
                      <span class="rounded-full bg-white/[0.07] px-3 py-1 text-xs font-semibold text-orange-50/70">
                        Ads
                      </span>
                    )}

                    {policy.features.analytics && (
                      <span class="rounded-full bg-white/[0.07] px-3 py-1 text-xs font-semibold text-orange-50/70">
                        Analytics
                      </span>
                    )}

                    {policy.features.crashReporting && (
                      <span class="rounded-full bg-white/[0.07] px-3 py-1 text-xs font-semibold text-orange-50/70">
                        Crash Reporting
                      </span>
                    )}

                    {policy.features.inAppPurchases && (
                      <span class="rounded-full bg-white/[0.07] px-3 py-1 text-xs font-semibold text-orange-50/70">
                        In-App Purchases
                      </span>
                    )}

                    {policy.features.notifications && (
                      <span class="rounded-full bg-white/[0.07] px-3 py-1 text-xs font-semibold text-orange-50/70">
                        Notifications
                      </span>
                    )}
                  </div>
                </div>

                <a
                  href={`/privacy-policy/${policy.slug}/`}
                  class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-black text-slate-950 transition hover:bg-orange-100"
                >
                  View Policy
                </a>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
