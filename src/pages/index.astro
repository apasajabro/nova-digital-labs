---
import BaseLayout from '../layouts/BaseLayout.astro';
import NovaHomeHero from '../components/sections/NovaHomeHero.astro';
import NovaHomeCapabilities from '../components/sections/NovaHomeCapabilities.astro';
import NovaHomeShowcase from '../components/sections/NovaHomeShowcase.astro';
import NovaHomeWorkflow from '../components/sections/NovaHomeWorkflow.astro';
import NovaHomeContactBand from '../components/sections/NovaHomeContactBand.astro';
import { company } from '../config/company';
---

<BaseLayout
  title={`${company.legalName} — Professional Software, Web, and Digital Solutions`}
  description={company.description}
>
  <NovaHomeHero />
  <NovaHomeCapabilities />
  <NovaHomeShowcase />
  <NovaHomeWorkflow />
  <NovaHomeContactBand />
</BaseLayout>
