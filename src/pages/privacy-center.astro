---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { company, appPrivacyPolicies } from '@/config/company';
---

<BaseLayout
  title="Privacy Policy Center"
  description="Privacy Policy Center for applications, digital products, and services published by PT Nova Digital Labs."
>
  <section class="section-padding">
    <div class="container-page">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-300">Privacy Center</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-6xl text-balance">
          Application Privacy Policy Center
        </h1>
        <p class="mt-6 text-base leading-8 text-slate-400">
          This page is prepared as a central directory for privacy policies related to applications and digital products published by {company.legalName}.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-5xl">
        <div class="rounded-3xl border border-brand-300/20 bg-brand-500/10 p-7">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-200">
                Coming Soon
              </p>
              <h2 class="mt-3 text-2xl font-bold text-white">
                App privacy policies will be added here.
              </h2>
              <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300">
                Once applications are published, each app can have its own privacy policy page and will be listed in this center for easy access.
              </p>
            </div>

            <span class="inline-flex rounded-full bg-white px-5 py-3 text-sm font-bold text-slate-950">
              In Preparation
            </span>
          </div>
        </div>

        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {appPrivacyPolicies.map((policy) => (
            <article class="card-glass p-7">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-sm font-semibold text-brand-200">{policy.platform}</p>
                  <h3 class="mt-2 text-xl font-bold text-white">{policy.name}</h3>
                </div>
                <span class="rounded-full border border-white/10 bg-white/[0.06] px-3 py-1 text-xs font-semibold text-slate-300">
                  {policy.status}
                </span>
              </div>

              <p class="mt-5 text-sm leading-7 text-slate-400">{policy.description}</p>

              {policy.slug ? (
                <a
                  href={`/privacy-center/${policy.slug}/`}
                  class="mt-6 inline-flex rounded-full bg-brand-500 px-5 py-3 text-sm font-bold text-white transition hover:bg-brand-400"
                >
                  View Policy
                </a>
              ) : (
                <button
                  type="button"
                  disabled
                  class="mt-6 inline-flex cursor-not-allowed rounded-full border border-white/10 px-5 py-3 text-sm font-bold text-slate-500"
                >
                  Not Available Yet
                </button>
              )}
            </article>
          ))}

          <article class="card-glass p-7">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-brand-200">Template Ready</p>
                <h3 class="mt-2 text-xl font-bold text-white">Easy to Add New App Policies</h3>
              </div>
              <span class="rounded-full border border-white/10 bg-white/[0.06] px-3 py-1 text-xs font-semibold text-slate-300">
                Ready
              </span>
            </div>

            <p class="mt-5 text-sm leading-7 text-slate-400">
              Future app privacy policies can be added by creating a dedicated page and registering the app in the privacy policy data list.
            </p>

            <a
              href={`mailto:${company.email}`}
              class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-bold text-white transition hover:bg-white/10"
            >
              Contact Publisher
            </a>
          </article>
        </div>

        <div class="mt-10 rounded-3xl border border-white/10 bg-white/[0.04] p-7">
          <h2 class="text-2xl font-bold text-white">For Users</h2>
          <p class="mt-4 text-sm leading-8 text-slate-400">
            If you are looking for the privacy policy of a specific application published by {company.legalName}, please return to this page once the application is publicly available. You may also contact us directly at
            <a class="font-semibold text-brand-200 transition hover:text-white" href={`mailto:${company.email}`}> {company.email}</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
