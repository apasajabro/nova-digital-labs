---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { company } from '../../config/company';
---

<BaseLayout
  title={`Privacy Policy — ${company.legalName}`}
  description={`Privacy policy information for applications and digital products by ${company.legalName}.`}
>
  <section class="section-padding">
    <div class="container-page">
      <div class="mx-auto max-w-3xl rounded-[2rem] border border-white/15 bg-white/[0.07] p-8 text-center shadow-soft backdrop-blur-xl sm:p-10">
        <p class="text-sm font-bold uppercase tracking-[0.32em] text-orange-200">
          Privacy Policy
        </p>

        <h1 class="mt-5 text-4xl font-black tracking-tight text-white">
          Privacy Policy Center
        </h1>

        <p class="mt-5 text-base leading-8 text-orange-50/65">
          Please visit the Privacy Policy Center to view available application privacy policies.
        </p>

        <a
          href="/privacy-center/"
          class="mt-8 inline-flex rounded-2xl bg-white px-6 py-4 text-sm font-black text-slate-950 transition hover:bg-orange-100"
        >
          Open Privacy Center
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
