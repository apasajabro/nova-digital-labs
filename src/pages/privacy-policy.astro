---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { company } from '@/config/company';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy Policy for PT Nova Digital Labs website, business inquiries, and digital service communication."
>
  <section class="section-padding">
    <div class="container-page">
      <div class="mx-auto max-w-4xl">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-300">Legal</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-6xl text-balance">
          Privacy Policy
        </h1>
        <p class="mt-6 text-base leading-8 text-slate-400">
          This Privacy Policy explains how {company.legalName} handles information related to this website, business inquiries, and communication with potential clients or partners.
        </p>

        <div class="mt-10 rounded-3xl border border-brand-300/20 bg-brand-500/10 p-6">
          <p class="text-sm leading-7 text-brand-100">
            This page applies to the official company profile website of {company.legalName}. Privacy policies for individual applications published by the company will be listed separately in the Privacy Policy Center.
          </p>
        </div>

        <div class="mt-12 space-y-10">
          <section class="card-glass p-7">
            <h2 class="text-2xl font-bold text-white">1. Information We May Receive</h2>
            <p class="mt-4 text-sm leading-8 text-slate-400">
              When visitors contact us through email or other communication channels, we may receive information voluntarily provided by the visitor, such as name, email address, company name, project details, business requirements, and related communication content.
            </p>
          </section>

          <section class="card-glass p-7">
            <h2 class="text-2xl font-bold text-white">2. How We Use Information</h2>
            <p class="mt-4 text-sm leading-8 text-slate-400">
              Information shared with us is used to respond to inquiries, understand project requirements, prepare service discussions, communicate with clients or potential clients, and improve the clarity of our business communication.
            </p>
          </section>

          <section class="card-glass p-7">
            <h2 class="text-2xl font-bold text-white">3. Website Analytics and Cookies</h2>
            <p class="mt-4 text-sm leading-8 text-slate-400">
              This static website may be operated without account registration, login, or direct payment processing. If analytics, embedded content, or third-party tools are added in the future, this Privacy Policy may be updated to explain how those services handle data.
            </p>
          </section>

          <section class="card-glass p-7">
            <h2 class="text-2xl font-bold text-white">4. Data Sharing</h2>
            <p class="mt-4 text-sm leading-8 text-slate-400">
              We do not sell personal information. Information may only be shared when required to provide requested services, comply with legal obligations, protect rights and security, or support agreed project-related communication.
            </p>
          </section>

          <section class="card-glass p-7">
            <h2 class="text-2xl font-bold text-white">5. Data Security</h2>
            <p class="mt-4 text-sm leading-8 text-slate-400">
              We take reasonable steps to protect communication and project-related information. However, no method of transmission over the internet is completely secure, and visitors should avoid sending highly sensitive information unless necessary and agreed through proper communication channels.
            </p>
          </section>

          <section class="card-glass p-7">
            <h2 class="text-2xl font-bold text-white">6. Application Privacy Policies</h2>
            <p class="mt-4 text-sm leading-8 text-slate-400">
              Privacy policies for applications published on Google Play or other platforms may have different terms depending on each application’s features, permissions, data usage, advertising, subscriptions, or third-party services.
            </p>
            <a
              href="/privacy-center/"
              class="mt-6 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-bold text-white transition hover:bg-white/10"
            >
              Visit Privacy Policy Center
            </a>
          </section>

          <section class="card-glass p-7">
            <h2 class="text-2xl font-bold text-white">7. Contact</h2>
            <p class="mt-4 text-sm leading-8 text-slate-400">
              If you have questions about this Privacy Policy, please contact {company.legalName} at:
            </p>
            <a
              class="mt-4 inline-flex break-all text-sm font-semibold text-brand-200 transition hover:text-white"
              href={`mailto:${company.email}`}
            >
              {company.email}
            </a>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
