---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mx-auto max-w-3xl text-center">
  <p class="text-sm font-semibold uppercase tracking-[0.28em] text-orange-200">{eyebrow}</p>
  <h2 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-5xl text-balance">{title}</h2>
  {description && <p class="mt-5 text-base leading-8 text-orange-50/65">{description}</p>}
</div>
