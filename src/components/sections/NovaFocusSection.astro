---
const focusItems = [
  {
    title: 'Digital Identity',
    description:
      'Building a professional business presence through websites, landing pages, clear service pages, and structured company information.',
    label: '01'
  },
  {
    title: 'Software Execution',
    description:
      'Transforming business needs into practical web applications, dashboards, workflow systems, and digital product interfaces.',
    label: '02'
  },
  {
    title: 'Launch Support',
    description:
      'Helping digital products become clearer, more maintainable, and better prepared for public release or business adoption.',
    label: '03'
  }
];
---

<section class="py-12">
  <div class="container-page">
    <div class="grid gap-5 rounded-[2rem] border border-white/15 bg-white/[0.07] p-5 shadow-soft backdrop-blur-xl md:grid-cols-3">
      {focusItems.map((item) => (
        <article class="rounded-3xl border border-white/10 bg-orange-950/35 p-6">
          <span class="text-sm font-bold text-orange-200">{item.label}</span>
          <h2 class="mt-4 text-xl font-bold text-white">{item.title}</h2>
          <p class="mt-4 text-sm leading-7 text-orange-50/65">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
