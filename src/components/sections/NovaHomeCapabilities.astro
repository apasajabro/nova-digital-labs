---
import { services } from '../../config/company';

const featuredServices = services.slice(0, 6);
---

<section class="section-padding">
  <div class="container-page">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-bold uppercase tracking-[0.32em] text-orange-200">
        What We Build
      </p>

      <h2 class="mt-5 text-3xl font-black tracking-tight text-white sm:text-4xl">
        Digital foundations for businesses that need more than a basic online presence.
      </h2>

      <p class="mt-5 text-base leading-8 text-orange-50/65">
        Nova focuses on practical digital delivery: clear structure, professional interface,
        reliable implementation, and release-ready execution.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {featuredServices.map((service, index) => (
        <article class="group flex min-h-[300px] flex-col justify-between rounded-[2rem] border border-white/15 bg-white/[0.07] p-6 shadow-soft backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-orange-200/35 hover:bg-white/[0.10]">
          <div>
            <div class="flex items-center justify-between">
              <span class="text-xs font-black uppercase tracking-[0.25em] text-orange-200/80">
                {String(index + 1).padStart(2, '0')}
              </span>

              <span class="h-2.5 w-2.5 rounded-full bg-brand-300 shadow-[0_0_24px_rgba(249,115,22,0.75)]"></span>
            </div>

            <h3 class="mt-10 text-2xl font-black leading-tight text-white">
              {service.title}
            </h3>

            <p class="mt-5 text-sm leading-7 text-orange-50/60">
              {service.description}
            </p>
          </div>

          <div class="mt-8 h-px w-full bg-gradient-to-r from-orange-300/50 via-rose-300/25 to-transparent"></div>
        </article>
      ))}
    </div>
  </div>
</section>
