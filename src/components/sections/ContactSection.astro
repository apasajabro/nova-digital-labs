---
import { company } from '@/config/company';
---

<section class="section-padding">
  <div class="container-page">
    <div class="card-glass grid gap-10 p-8 md:p-12 lg:grid-cols-[1fr_0.8fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-brand-300">Contact</p>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-5xl text-balance">
          Let’s discuss your next digital project.
        </h2>
        <p class="mt-5 max-w-2xl text-base leading-8 text-slate-400">
          Contact PT Nova Digital Labs for company profile websites, landing pages, business applications, and digital product development support.
        </p>
      </div>

      <div class="rounded-3xl border border-white/10 bg-slate-900/70 p-6">
        <p class="text-sm text-slate-400">Business Email</p>
        <a class="mt-2 block break-words text-lg font-semibold text-white transition hover:text-brand-200" href={`mailto:${company.email}`}>
          {company.email}
        </a>

        <div class="mt-6 border-t border-white/10 pt-6">
          <p class="text-sm text-slate-400">Location</p>
          <p class="mt-2 text-lg font-semibold text-white">{company.address}</p>
        </div>

        <a
          href={`mailto:${company.email}`}
          class="mt-8 inline-flex w-full items-center justify-center rounded-2xl bg-brand-500 px-6 py-4 text-center text-sm font-bold text-white transition hover:bg-brand-400"
        >
          Send Project Inquiry
        </a>
      </div>
    </div>
  </div>
</section>
