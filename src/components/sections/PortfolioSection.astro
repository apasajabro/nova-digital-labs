---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { portfolio } from '@/config/company';

interface Props {
  compact?: boolean;
}

const compact = Astro.props.compact ?? false;
const items = compact ? portfolio.slice(0, 3) : portfolio;
---

<section class="section-padding">
  <div class="container-page">
    <SectionHeader
      eyebrow="Portfolio"
      title="Project categories and digital work focus"
      description="A curated overview of digital project categories that PT Nova Digital Labs can support, from company profile websites to business software and mobile applications."
    />

    <div class="mt-14 grid gap-7 md:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <article class="group overflow-hidden rounded-3xl border border-white/10 bg-white/[0.06] shadow-soft backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-brand-300/30 hover:bg-white/[0.08]">
          <div class="relative h-60 overflow-hidden bg-slate-900">
            <img
              src={item.imageUrl}
              alt={item.imageAlt}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent"></div>

            <div class="absolute left-5 top-5">
              <span class="rounded-full border border-white/15 bg-slate-950/55 px-4 py-2 text-xs font-semibold text-white backdrop-blur-xl">
                {item.category}
              </span>
            </div>
          </div>

          <div class="p-7">
            <h3 class="text-xl font-bold text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 text-slate-400">{item.description}</p>

            <div class="mt-6 flex flex-wrap gap-2">
              {item.scope.map((scopeItem) => (
                <span class="rounded-full border border-white/10 bg-white/[0.05] px-3 py-1.5 text-xs font-medium text-slate-300">
                  {scopeItem}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    {compact && (
      <div class="mt-12 text-center">
        <a
          href="/portfolio/"
          class="inline-flex items-center justify-center rounded-full border border-white/15 px-7 py-4 text-sm font-bold text-white transition hover:bg-white/10"
        >
          View All Project Categories
        </a>
      </div>
    )}
  </div>
</section>
