---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { process } from '@/config/company';
---

<section class="section-padding">
  <div class="container-page">
    <SectionHeader
      eyebrow="Process"
      title="A clear workflow from discussion to launch"
      description="Every project starts with understanding the business need, then moves into structure, design, development, and review."
    />

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {process.map((item, index) => (
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-7">
          <span class="text-sm font-bold text-brand-300">Step {index + 1}</span>
          <h3 class="mt-4 text-xl font-bold text-white">{item.title}</h3>
          <p class="mt-4 text-sm leading-7 text-slate-400">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
