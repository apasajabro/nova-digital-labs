---
import { portfolio } from '../../config/company';

const mainItem = portfolio[0];
const sideItems = portfolio.slice(1, 4);
---

<section class="py-10 sm:py-14">
  <div class="container-page">
    <div class="overflow-hidden rounded-[2.5rem] border border-white/15 bg-white/[0.07] shadow-soft backdrop-blur-xl">
      <div class="grid lg:grid-cols-[1.1fr_0.9fr]">
        <div class="relative min-h-[460px]">
          <img
            src={mainItem.imageUrl}
            alt={mainItem.imageAlt}
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-slate-950/85 via-slate-950/50 to-orange-950/65"></div>

          <div class="relative flex min-h-[460px] flex-col justify-end p-7 sm:p-10">
            <p class="text-sm font-bold uppercase tracking-[0.32em] text-orange-200">
              Featured Direction
            </p>
            <h2 class="mt-4 max-w-2xl text-3xl font-black text-white sm:text-5xl">
              {mainItem.title}
            </h2>
            <p class="mt-5 max-w-2xl text-base leading-8 text-orange-50/70">
              {mainItem.description}
            </p>

            <div class="mt-7 flex flex-wrap gap-3">
              {mainItem.scope.map((scope) => (
                <span class="rounded-full border border-orange-200/25 bg-orange-300/10 px-4 py-2 text-xs font-bold text-orange-100">
                  {scope}
                </span>
              ))}
            </div>
          </div>
        </div>

        <div class="grid divide-y divide-white/10">
          {sideItems.map((item) => (
            <article class="group p-7 transition hover:bg-white/[0.06] sm:p-8">
              <p class="text-xs font-black uppercase tracking-[0.28em] text-orange-200/70">
                {item.category}
              </p>

              <div class="mt-5 flex items-start justify-between gap-6">
                <div>
                  <h3 class="text-2xl font-black text-white">{item.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-orange-50/60">{item.description}</p>
                </div>
                <span class="mt-1 text-2xl text-orange-100/35 transition group-hover:translate-x-1 group-hover:text-orange-100">
                  →
                </span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
