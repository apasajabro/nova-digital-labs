---
import { company } from '@/config/company';
---

<section class="relative overflow-hidden">
  <div class="container-page grid min-h-[calc(100vh-5rem)] items-center gap-12 py-20 lg:grid-cols-[0.95fr_1.05fr]">
    <div>
      <p class="inline-flex rounded-full border border-orange-200/30 bg-orange-300/10 px-4 py-2 text-sm font-medium text-orange-100">
        {company.legalName}
      </p>

      <h1 class="mt-7 max-w-4xl text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl text-balance">
        Digital systems built to connect business, product, and technology.
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-9 text-orange-50/75">
        {company.description}
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-brand-300 via-accent-400 to-violetnova-400 px-7 py-4 text-sm font-bold text-slate-950 shadow-lg shadow-brand-300/25 transition hover:opacity-90"
        >
          Discuss a Project
        </a>
        <a
          href="/portfolio/"
          class="inline-flex items-center justify-center rounded-full border border-orange-100/25 bg-white/[0.04] px-7 py-4 text-sm font-bold text-white transition hover:bg-white/10"
        >
          Explore Work Focus
        </a>
      </div>

      <div class="mt-12 grid max-w-xl grid-cols-3 gap-3">
        <div class="rounded-2xl border border-white/15 bg-white/[0.07] p-4 backdrop-blur-xl">
          <strong class="block text-2xl text-white">Web</strong>
          <span class="mt-1 block text-xs leading-5 text-orange-50/60">Company sites and landing pages</span>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/[0.07] p-4 backdrop-blur-xl">
          <strong class="block text-2xl text-white">App</strong>
          <span class="mt-1 block text-xs leading-5 text-orange-50/60">Mobile and digital products</span>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/[0.07] p-4 backdrop-blur-xl">
          <strong class="block text-2xl text-white">Ops</strong>
          <span class="mt-1 block text-xs leading-5 text-orange-50/60">Business system support</span>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -left-8 -top-8 h-36 w-36 rounded-full bg-brand-300/25 blur-3xl"></div>
      <div class="absolute -bottom-8 -right-8 h-44 w-44 rounded-full bg-accent-400/25 blur-3xl"></div>

      <div class="relative rounded-[2rem] border border-white/15 bg-white/[0.08] p-4 shadow-glow backdrop-blur-xl">
        <div class="rounded-[1.5rem] border border-white/10 bg-orange-950/70 p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm text-orange-50/60">Nova Build Matrix</p>
              <h2 class="mt-1 text-2xl font-bold text-white">Digital Delivery Stack</h2>
            </div>
            <span class="rounded-full bg-orange-300/15 px-3 py-1 text-xs font-semibold text-orange-100">
              Active
            </span>
          </div>

          <div class="mt-6 grid gap-4">
            <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <h3 class="font-bold text-white">Business Website</h3>
                  <p class="mt-1 text-sm text-orange-50/55">Profile, services, portfolio, and inquiry flow.</p>
                </div>
                <span class="h-3 w-3 rounded-full bg-orange-300"></span>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5">
                <p class="text-sm text-orange-50/55">Application Layer</p>
                <h3 class="mt-2 text-xl font-bold text-white">Web App</h3>
              </div>
              <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5">
                <p class="text-sm text-orange-50/55">Product Layer</p>
                <h3 class="mt-2 text-xl font-bold text-white">Mobile App</h3>
              </div>
            </div>

            <div class="rounded-3xl border border-white/10 bg-gradient-to-r from-cyan-300/15 to-violet-400/15 p-5">
              <p class="text-sm leading-7 text-orange-50/75">
                Nova Digital Labs helps companies prepare practical digital foundations through websites, interfaces, applications, and technical product support.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mx-auto mt-5 grid max-w-lg grid-cols-3 gap-3 text-center">
        {['Plan', 'Build', 'Launch'].map((item) => (
          <div class="rounded-2xl border border-white/10 bg-white/[0.05] px-4 py-3 text-sm font-semibold text-cyan-50/80">
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
