---
import { company } from '../../config/company';
---

<section class="pb-20 sm:pb-24">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-[2.5rem] border border-white/15 bg-gradient-to-br from-orange-500/20 via-rose-500/15 to-violet-500/15 p-7 shadow-soft backdrop-blur-xl sm:p-10">
      <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-orange-300/20 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-rose-300/20 blur-3xl"></div>

      <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.32em] text-orange-100/75">
            Project Inquiry
          </p>

          <h2 class="mt-4 max-w-3xl text-3xl font-black tracking-tight text-white sm:text-5xl">
            Need a professional digital presence for your business?
          </h2>

          <p class="mt-5 max-w-2xl text-base leading-8 text-orange-50/70">
            Contact {company.legalName} to discuss websites, web applications, landing pages,
            mobile apps, or digital product support.
          </p>
        </div>

        <div class="rounded-3xl border border-white/15 bg-slate-950/55 p-5">
          <p class="text-xs uppercase tracking-[0.24em] text-orange-100/55">Email</p>
          <a
            href={`mailto:${company.email}`}
            class="mt-3 block break-all text-lg font-black text-white transition hover:text-orange-200"
          >
            {company.email}
          </a>

          <a
            href="/contact/"
            class="mt-6 block rounded-2xl bg-white px-6 py-4 text-center text-sm font-black text-slate-950 transition hover:bg-orange-100"
          >
            Open Contact Page
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
