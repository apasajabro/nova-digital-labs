---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { services } from '@/config/company';
---

<section class="section-padding">
  <div class="container-page">
    <SectionHeader
      eyebrow="Services"
      title="Technology services arranged for practical business needs"
      description="Nova Digital Labs provides focused digital services for websites, applications, business tools, and product support."
    />

    <div class="mt-14 grid gap-6 lg:grid-cols-4">
      {services.map((service, index) => {
        const isLarge = index === 0 || index === 1;
        return (
          <article
            class:list={[
              'group rounded-3xl border border-white/15 bg-white/[0.07] p-7 shadow-soft backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-orange-200/40 hover:bg-white/[0.10]',
              isLarge ? 'lg:col-span-2' : 'lg:col-span-1'
            ]}
          >
            <div class="flex items-start justify-between gap-4">
              <span class="grid h-12 w-12 place-items-center rounded-2xl bg-gradient-to-br from-brand-300 via-accent-400 to-violetnova-400 text-sm font-bold text-slate-950">
                0{index + 1}
              </span>
              <span class="rounded-full border border-white/10 bg-white/[0.06] px-3 py-1 text-xs font-semibold text-orange-50/70">
                Nova
              </span>
            </div>

            <h3 class="mt-7 text-xl font-bold text-white">{service.title}</h3>
            <p class="mt-4 text-sm leading-7 text-orange-50/65">{service.description}</p>

            <div class="mt-7 h-1.5 overflow-hidden rounded-full bg-white/10">
              <div
                class:list={[
                  'h-full rounded-full bg-gradient-to-r from-brand-300 via-accent-400 to-violetnova-400 transition-all duration-500',
                  index === 0 ? 'w-[92%]' : '',
                  index === 1 ? 'w-[86%]' : '',
                  index === 2 ? 'w-[78%]' : '',
                  index === 3 ? 'w-[72%]' : '',
                  index === 4 ? 'w-[68%]' : '',
                  index === 5 ? 'w-[74%]' : ''
                ]}
              ></div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
