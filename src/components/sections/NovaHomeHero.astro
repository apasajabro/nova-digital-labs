---
import { company } from '../../config/company';
---

<section class="relative overflow-hidden pt-16 sm:pt-20 lg:pt-24">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-stretch">
      <div class="flex min-h-[520px] flex-col justify-between rounded-[2.5rem] border border-white/15 bg-white/[0.07] p-7 shadow-soft backdrop-blur-xl sm:p-9">
        <div>
          <p class="inline-flex rounded-full border border-orange-200/25 bg-orange-300/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.32em] text-orange-100">
            Digital Product Lab
          </p>

          <h1 class="mt-8 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl">
            Building digital systems with clarity, speed, and business focus.
          </h1>

          <p class="mt-6 max-w-2xl text-base leading-8 text-orange-50/70 sm:text-lg">
            {company.legalName} helps businesses build professional websites, web applications,
            landing pages, and digital product foundations that are clear, maintainable, and ready
            to grow.
          </p>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          <a
            href="/contact/"
            class="rounded-2xl bg-gradient-to-r from-brand-300 via-accent-400 to-violetnova-400 px-6 py-4 text-center text-sm font-extrabold text-slate-950 shadow-glow transition hover:scale-[1.01]"
          >
            Start a Project
          </a>

          <a
            href="/portfolio/"
            class="rounded-2xl border border-white/15 bg-white/10 px-6 py-4 text-center text-sm font-bold text-white transition hover:bg-white/15"
          >
            View Capabilities
          </a>
        </div>
      </div>

      <div class="relative rounded-[2.5rem] border border-white/15 bg-slate-950/70 p-5 shadow-soft backdrop-blur-xl sm:p-6">
        <div class="absolute inset-0 rounded-[2.5rem] bg-[radial-gradient(circle_at_30%_20%,rgba(249,115,22,0.28),transparent_22rem),radial-gradient(circle_at_80%_70%,rgba(244,63,94,0.20),transparent_22rem)]"></div>

        <div class="relative grid min-h-[520px] gap-5 lg:grid-rows-[auto_1fr_auto]">
          <div class="flex items-center justify-between rounded-3xl border border-white/10 bg-white/[0.07] px-5 py-4">
            <div>
              <p class="text-xs uppercase tracking-[0.28em] text-orange-100/60">Nova Console</p>
              <p class="mt-1 text-sm font-bold text-white">Project Readiness Matrix</p>
            </div>
            <span class="rounded-full bg-emerald-300/15 px-3 py-1 text-xs font-bold text-emerald-200">
              Active
            </span>
          </div>

          <div class="grid gap-5 md:grid-cols-[0.8fr_1.2fr]">
            <div class="space-y-5">
              <div class="rounded-3xl border border-white/10 bg-white/[0.08] p-5">
                <p class="text-xs uppercase tracking-[0.24em] text-orange-100/60">Focus</p>
                <p class="mt-4 text-4xl font-black text-white">04</p>
                <p class="mt-2 text-sm text-orange-50/60">Core digital delivery lanes</p>
              </div>

              <div class="rounded-3xl border border-white/10 bg-white/[0.08] p-5">
                <p class="text-xs uppercase tracking-[0.24em] text-orange-100/60">Delivery</p>
                <div class="mt-5 h-3 overflow-hidden rounded-full bg-white/10">
                  <div class="h-full w-[82%] rounded-full bg-gradient-to-r from-brand-300 to-accent-400"></div>
                </div>
                <p class="mt-3 text-sm text-orange-50/60">Structured build process</p>
              </div>
            </div>

            <div class="rounded-3xl border border-orange-200/20 bg-orange-950/30 p-5">
              <p class="text-xs uppercase tracking-[0.24em] text-orange-100/60">System Layers</p>

              <div class="mt-6 space-y-3">
                {['Business Website', 'Web Application', 'Mobile Product', 'Launch Support'].map((item, index) => (
                  <div class="group flex items-center justify-between rounded-2xl border border-white/10 bg-white/[0.07] px-4 py-4 transition hover:bg-white/[0.11]">
                    <div class="flex items-center gap-3">
                      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-300 to-accent-400 text-sm font-black text-slate-950">
                        {String(index + 1).padStart(2, '0')}
                      </span>
                      <span class="text-sm font-bold text-white">{item}</span>
                    </div>
                    <span class="text-orange-100/40 transition group-hover:text-orange-100">→</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-3">
            {[
              ['Web', 'Company profile & landing page'],
              ['App', 'Business system & mobile app'],
              ['Ops', 'Maintenance & launch support']
            ].map(([title, desc]) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.07] p-4">
                <p class="text-lg font-black text-white">{title}</p>
                <p class="mt-2 text-xs leading-5 text-orange-50/55">{desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
