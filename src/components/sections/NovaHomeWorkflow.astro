---
import { process } from '../../config/company';
---

<section class="section-padding">
  <div class="container-page">
    <div class="mb-10 flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.32em] text-orange-200">
          Delivery Flow
        </p>
        <h2 class="mt-5 max-w-2xl text-3xl font-black tracking-tight text-white sm:text-4xl">
          From unclear idea to structured digital product direction.
        </h2>
      </div>

      <p class="max-w-xl text-base leading-8 text-orange-50/65">
        We keep the process simple, visible, and practical so every step supports business clarity
        and technical execution.
      </p>
    </div>

    <div class="relative">
      <div class="absolute left-6 right-6 top-10 hidden h-px bg-gradient-to-r from-brand-300 via-accent-400 to-violetnova-400 lg:block"></div>

      <div class="grid gap-5 lg:grid-cols-4">
        {process.map((step, index) => (
          <article class="relative rounded-[2rem] border border-white/12 bg-slate-950/60 p-6 shadow-soft backdrop-blur-xl">
            <div class="flex h-20 w-20 items-center justify-center rounded-3xl border border-orange-200/25 bg-orange-300/10 text-2xl font-black text-orange-100">
              {String(index + 1).padStart(2, '0')}
            </div>

            <h3 class="mt-8 text-xl font-black text-white">{step.title}</h3>
            <p class="mt-4 text-sm leading-7 text-orange-50/60">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
